# Copy to deploy/.env and fill in. Used by docker-compose.yml.

# --- App runtime LLM (DeepSeek, BYOK) ---
# This is the LLM the PRODUCT uses (Open Notebook analysis + Presenton generation).
# Development-loop keys (Claude + DeepSeek for Aider) live in automation/.env, not here.
DEEPSEEK_API_KEY=changeme
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# --- Embeddings provider for Open Notebook (DeepSeek has no embeddings) ---
# Option A (data stays on VPS): local Ollama embeddings.
OLLAMA_URL=http://ollama:11434
EMBEDDING_MODEL=bge-m3
# Option B (external): set an OpenAI/Mistral/Voyage embeddings key instead.
# OPENAI_API_KEY=

# --- Presenton image provider ---
IMAGE_PROVIDER=pexels
PEXELS_API_KEY=changeme         # or switch IMAGE_PROVIDER to dall-e-3 / gemini_flash (+ that key)

# --- Orchestrator ---
ORCH_SECRET_KEY=change-me-long-random   # also derives the BYOK encryption key
PUBLIC_BASE_URL=https://app.localhost
ENVIRONMENT=development                  # production | development | test
LOG_LEVEL=INFO

# --- PostgreSQL (system of record) ---
POSTGRES_USER=orch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=orchestrator
DATABASE_URL=postgresql+psycopg://orch:change-me@postgres:5432/orchestrator

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- MinIO (object storage) ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=presentations
MINIO_ENDPOINT=http://minio:9000

# --- OIDC (Keycloak/Authentik) ---
OIDC_ISSUER=https://auth.localhost/realms/main
OIDC_CLIENT_ID=orchestrator
OIDC_CLIENT_SECRET=change-me
OIDC_AUDIENCE=                            # optional; verified only when set
# Dev only: accept HS256 tokens signed with ORCH_SECRET_KEY so the stack runs
# without a live IdP. NEVER set true in production.
OIDC_DEV_MODE=false

# --- Frontend (public, baked into the browser bundle at build time) ---
# Same-origin API via Traefik; only override for split-origin local dev.
NEXT_PUBLIC_API_BASE=/api/v1
NEXT_PUBLIC_OIDC_ISSUER=https://auth.localhost/realms/main
NEXT_PUBLIC_OIDC_CLIENT_ID=orchestrator
NEXT_PUBLIC_OIDC_REDIRECT_URI=https://app.localhost/auth/callback
NEXT_PUBLIC_DEV_MODE=false                # shows the dev-token login form

# --- Open Notebook (internal engine) ---
OPEN_NOTEBOOK_URL=http://open-notebook:5055
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-secret
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# --- Presenton (internal engine) ---
PRESENTON_URL=http://presenton:80
PRESENTON_AUTH_USERNAME=admin
PRESENTON_AUTH_PASSWORD=change-me123
PRESENTON_CAN_CHANGE_KEYS=false
