# =============================================================================
# NotebookLLM-Lite — demo environment (single-tenant, no auth)
# Copy to deploy/.env.lite and fill in, then use docker-compose.lite.yml.
#   cp deploy/.env.lite.example deploy/.env.lite
# =============================================================================

# --- Lite mode switch (backend) -------------------------------------------
# true  = single-tenant demo: no login, no quotas, LLM from OPENROUTER_* below.
# false = full multi-tenant SaaS (OIDC, RBAC, per-tenant BYOK, metering).
LITE_MODE=true

# Fixed default workspace + admin. The backend derives stable ids from these
# (uuid5) and the seed step creates the matching rows. Changing the slug/email
# after seeding creates a NEW empty workspace — pick them once.
DEFAULT_TENANT_SLUG=demo
DEFAULT_TENANT_NAME=Demo Workspace
DEFAULT_USER_EMAIL=demo@local

# --- OpenRouter (the product LLM: outline + analysis + slide generation) ---
# Chat-completions only. Get a key at https://openrouter.ai/keys.
# Set OPENROUTER_MODEL to the exact slug you want to demo (confirm it exists in
# the OpenRouter model list). Examples: deepseek/deepseek-chat-v3, deepseek/deepseek-r1
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-changeme
OPENROUTER_MODEL=deepseek/deepseek-chat-v3
# Optional: curated model slugs offered in the Studio dropdown (CSV).
# OPENROUTER_MODELS=deepseek/deepseek-chat-v3,openai/gpt-4o-mini,anthropic/claude-3.5-sonnet

# --- AI output language ----------------------------------------------------
# Language NAME (not an ISO code) for decks + the guide/chat prompts. Defaults
# target Indonesian users; users can still switch per deck / in the UI.
# DEFAULT_LANGUAGE=Bahasa Indonesia
# LANGUAGES=Bahasa Indonesia,English

# --- Embeddings for Open Notebook (RAG index) -----------------------------
# OpenRouter has NO embeddings endpoint, so document analysis needs a separate
# embeddings provider. OpenAI is the default here. (You can reuse this key or a
# dedicated one.) Confirm/enter these in the Open Notebook UI on first run.
OPENAI_API_KEY=sk-changeme
EMBEDDING_MODEL=text-embedding-3-small

# --- Presenton (slide generation engine → OpenRouter) ---------------------
PRESENTON_AUTH_USERNAME=admin
PRESENTON_AUTH_PASSWORD=change-me123
PRESENTON_CAN_CHANGE_KEYS=false
# Slide images. pexels (free key) or switch to dall-e-3 / gemini_flash (+ that key).
IMAGE_PROVIDER=pexels
PEXELS_API_KEY=changeme

# --- Orchestrator runtime -------------------------------------------------
ORCH_SECRET_KEY=change-me-long-random    # still used for at-rest crypto helpers
PUBLIC_BASE_URL=http://localhost:8080    # used for OpenRouter HTTP-Referer header
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- PostgreSQL (system of record) ----------------------------------------
POSTGRES_USER=orch
POSTGRES_PASSWORD=change-me
POSTGRES_DB=orchestrator
DATABASE_URL=postgresql+psycopg://orch:change-me@postgres:5432/orchestrator

# --- Redis (queue) --------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- MinIO (object storage for uploads + generated decks) -----------------
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET=presentations
MINIO_ENDPOINT=http://minio:9000

# --- Open Notebook internal store (SurrealDB) -----------------------------
OPEN_NOTEBOOK_URL=http://open-notebook:5055
OPEN_NOTEBOOK_ENCRYPTION_KEY=change-me-secret
SURREAL_USER=root
SURREAL_PASSWORD=root
SURREAL_NAMESPACE=open_notebook
SURREAL_DATABASE=open_notebook

# --- Presenton internal URL (orchestrator → engine) -----------------------
PRESENTON_URL=http://presenton:80

# --- Frontend (baked into the browser bundle at BUILD time) ---------------
# Same-origin API via Traefik, so this stays a relative path.
NEXT_PUBLIC_API_BASE=/api/v1
NEXT_PUBLIC_LITE_MODE=true
NEXT_PUBLIC_DEFAULT_TENANT_NAME=Demo Workspace

# NOTE: no OIDC_* / NEXT_PUBLIC_OIDC_* vars are needed in lite mode.
