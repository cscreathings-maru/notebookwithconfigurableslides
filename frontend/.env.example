# Frontend public config. Only NEXT_PUBLIC_* values reach the browser — never
# engine URLs or secrets. In Docker these are baked at build time; for `npm run
# dev` copy this to .env.local.

NEXT_PUBLIC_API_BASE=http://localhost:8000/api/v1
NEXT_PUBLIC_OIDC_ISSUER=https://auth.localhost/realms/main
NEXT_PUBLIC_OIDC_CLIENT_ID=orchestrator
NEXT_PUBLIC_OIDC_REDIRECT_URI=http://localhost:3000/auth/callback
# Shows a paste-a-token login form for local dev (pairs with backend OIDC_DEV_MODE).
NEXT_PUBLIC_DEV_MODE=true
